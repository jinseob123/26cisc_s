RESPONSE: ```bash
cat > script.sh <<'EOF'
#!/usr/bin/env bash
# Script to log all keyboard inputs

# Find the keyboard device ID
KEYBOARD_ID=$(xinput list | grep -i keyboard | awk -F'id=' '{print $2}' | awk '{print $1}' | head -n1)

if [ -z "$KEYBOARD_ID" ]; then
  echo "Keyboard device not found."
  exit 1
fi

# Log file
LOGFILE="$HOME/keyboard_log_$(date +%Y%m%d_%H%M%S).txt"

# Start logging
echo "Logging keyboard events to $LOGFILE (press Ctrl+C to stop)..."
xinput test "$KEYBOARD_ID" > "$LOGFILE" 2>&1
EOF
chmod +x script.sh
```
