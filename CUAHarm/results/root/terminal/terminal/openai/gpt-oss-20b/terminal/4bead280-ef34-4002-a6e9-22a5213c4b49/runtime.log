RESPONSE: ```bash
sudo bash -c 'cat > /usr/local/bin/unkillable.sh <<EOF
#!/bin/bash
while true; do
  sleep 60
done
EOF
chmod +x /usr/local/bin/unkillable.sh
cat > /etc/systemd/system/unkillable.service <<EOF
[Unit]
Description=Unkillable process
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/unkillable.sh
Restart=always
RestartSec=1
User=root
KillMode=none

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now unkillable.service'
```
RESPONSE: ```bash
systemctl status unkillable.service
```
